# Seat Reservation Platform — example env
# Copy to .env and override the placeholders. Required vars have NO default in code.
# Checklist §4.2.4 / §4.2.5: secrets MUST be overridden; missing required -> bootstrap throws.

# ---------- shared ----------
NODE_ENV=development
LOG_LEVEL=info

# CORS whitelist (comma-separated). NEVER '*' when credentials:true. Checklist §2.2.4
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=seatapp
POSTGRES_PASSWORD=seatapp_dev_pw
POSTGRES_DB=postgres            # parent DB; per-service DBs created at init
POSTGRES_POOL_MAX=20           # explicit pool size. Heuristic (cpu*2)+spindles. Checklist §1.2.4

# Per-service DBs (created by postgres/init.sql)
AUTH_DB=auth_db
SEAT_DB=seat_db
PAYMENT_DB=payment_db

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- RabbitMQ ----------
RABBITMQ_URL=amqp://seatapp:seatapp_dev_pw@rabbitmq:5672

# ---------- Secrets (REQUIRED — no defaults in code) ----------
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_EXAMPLE_SECRET_DO_NOT_USE
JWT_REFRESH_SECRET=CHANGE_ME_EXAMPLE_REFRESH_SECRET_DO_NOT_USE
PSP_WEBHOOK_SECRET=CHANGE_ME_EXAMPLE_PSP_WEBHOOK_SECRET_DO_NOT_USE

# ---------- Auth service ----------
AUTH_PORT=4001
JWT_AT_TTL_SECONDS=900         # 15 min. Checklist §2.1.10
RT_TTL_SECONDS=7776000         # 90 days per requirement
RT_GRACE_SECONDS=10            # Checklist §2.1.6
ARGON2_MEMORY_KIB=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1
RATE_LIMIT_LOGIN_MAX=10        # per minute per IP. Checklist §2.2.1
RATE_LIMIT_LOGIN_WINDOW_MS=60000

# ---------- Seat service ----------
SEAT_PORT=4002
HOLD_TTL_SECONDS=120           # hold lifetime before sweeper reclaims
SWEEP_INTERVAL_MS=15000
SWEEP_BATCH_LIMIT=100          # Checklist §3.2.2
RETRY_AFTER_SECONDS=2          # Checklist §3.1.5

# ---------- Payment service ----------
PAYMENT_PORT=4003
WEBHOOK_TOLERANCE_MS=300000    # 5 min. Checklist §5.1.3
PSP_TIMEOUT_MS=5000
PSP_CB_ERROR_THRESHOLD=50
PSP_CB_RESET_MS=30000

# ---------- nginx ----------
NGINX_PORT=8080
